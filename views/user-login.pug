extends layout.pug

block content
  div(style={'display': 'flex', 'justify-content': 'space-between', 'margin-top': '100px'})
   if errors
     div(class='alert alert-danger' role='alert')
       p The following error(s) occurred:
       ul
         each error in errors
           li= error
   form(class='loginForm', action='/user/login' method='post')
     input(type='hidden' name='_csrf' value=csrfToken)
     div(class='loginFormText', class='form-group')
       label(for='emailAddress') Email
       input(type='email' id='emailAddress' name='emailAddress' value='' class='form-control')
     div(class='loginFormText', class='form-group')
       label(for='password') Password
       input(type='password' id='password' name='password' value='' class='form-control')
     div(class='py-4')
       button(type='submit' class='btn' style={"background-color": "#080F5B", "color": "white", "margin-right": "6px", "width": "80px"}) Login
   footer(class='footerMain')
     nav(class='footerNav')
      p Copyright 2022
   div
    h4(style={'font-family': 'Georgia', 'font-size': '30px', 'text-align': 'center'}) Powering Scripts For Your Business
    br
    img(src='../public/images/5031659.jpg' style={"max-width": "500px", "max-height": "400px"})