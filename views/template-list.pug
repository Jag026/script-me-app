extends layout.pug

block content
  div(class='py-3')
  br
  br
  div(style={display: 'flex', 'justify-content': 'space-between', 'max-width': '900px', 'margin': '0 auto'})
    h4 Clone A Template: 
    a(class='btn btn-success' href=`/script/add` role='button') Add Script
  br  
  
  if scripts && scripts.length > 0
    each script in scripts
      div(class='scriptDesign')
       h4(class='scriptTitle')= script.title
         div(class="scriptButtonDiv")
           a(class='btn' style={"margin-right": '14px', 'color': 'white', 'background-color': '#080F5B'} href=`/template/${script.id}` role='button') View
           a(class='btn' style={"margin-right": '14px', 'background-color': '#fec107'} href=`template/add/${script.id}` role='button') Clone Script
  else
     p: em You don't have any scripts!

